# ─────────────────────────────────────────────────────────────────────
# APRIL 2026 RED TEAM STACK — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in values
# NEVER commit .env to git — it is git-ignored
# ─────────────────────────────────────────────────────────────────────

# ── LLM API KEYS ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...

# Optional cost-reduction backends (Claude/OpenAI if not set)
DEEPSEEK_API_KEY=sk-...               # 37x cheaper than GPT-4o for bulk tasks
GROQ_API_KEY=gsk_...                  # Fast inference for simple tasks
OLLAMA_BASE_URL=http://localhost:11434 # Local models (privacy-sensitive data)

# ── HEXSTRIKE AI ──────────────────────────────────────────────────────
HEXSTRIKE_API_TOKEN=                  # Generate: openssl rand -hex 32
HEXSTRIKE_API_URL=http://localhost:8888
HEXSTRIKE_MCP_PORT=8889

# HexStrike Community Edition (alternative to apt install)
# HEXSTRIKE_IMAGE=dennisleetw/hexstrike-ai:latest
# HEXSTRIKE_COMMUNITY_EDITION=false

# ── KALI MCP ──────────────────────────────────────────────────────────
KALI_MCP_PORT=8000
KALI_MCP_TOKEN=                       # Generate: openssl rand -hex 32
KALI_SSH_PORT=2222
KALI_SSH_USER=kali
KALI_PASSWORD=                        # Generate: openssl rand -base64 16
# SSH key auto-generated at: ~/.ssh/kali_mcp_ed25519

# ── PENTEST TOOLS ─────────────────────────────────────────────────────
# PentestGPT
PENTESTGPT_MODEL=claude-sonnet-4-20250514
PENTESTGPT_NO_TELEMETRY=true

# VulnGPT v2
VULNGPT_PORT=8090
SHODAN_API_KEY=                       # shodan.io — $49/month for full access
NVD_API_KEY=                          # Free: nvd.nist.gov/developers/request-an-api-key

# STRIDE-GPT (ThreatGPT)
STRIDE_GPT_PORT=8501

# AutoGPT
AUTOGPT_WORKSPACE=./autogpt_workspace
AUTOGPT_FAST_LLM=gpt-4o-mini          # or deepseek-chat for cost savings
AUTOGPT_SMART_LLM=claude-sonnet-4-20250514

# ── DATABASE (PostgreSQL) ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rtdb
POSTGRES_USER=rtuser
POSTGRES_PASSWORD=                    # Generate: openssl rand -base64 24

# ── MONITORING (Redis + Prometheus + Grafana) ─────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=                     # Generate: openssl rand -base64 16

# ── OSINT / INTELLIGENCE ──────────────────────────────────────────────
# Passive intelligence sources
SECURITYTRAILS_API_KEY=               # securitytrails.com — subdomain/DNS history
CENSYS_API_ID=                        # censys.io — internet-wide scan data
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=                   # virustotal.com — malware/IOC lookup
ALIENVAULT_OTX_KEY=                   # otx.alienvault.com — threat intel feeds
GITHUB_TOKEN=ghp_...                  # GitHub API — code/secret search (40 req/min auth vs 10 unauth)
HUNTER_IO_KEY=                        # hunter.io — email format discovery

# ── OPTIONAL EXTENDED TOOLS ───────────────────────────────────────────
# PentAGI
PENTAGI_PORT=8080
PENTAGI_API_KEY=                      # Auto-generated on first start

# CAI (Ostorlab)
CAI_API_KEY=

# AutoPentest-AI
AUTOPENTEST_MCP_PORT=8891

# Canarytokens (honeypot integration)
CANARYTOKEN_API_KEY=                  # canarytokens.org — free

# ── CLOUD TESTING CREDENTIALS ─────────────────────────────────────────
# AWS (for authorized cloud testing — set per-engagement)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-2

# GCP (for authorized cloud testing — set per-engagement)
# GOOGLE_APPLICATION_CREDENTIALS=./keys/gcp_sa_key.json
# GOOGLE_CLOUD_PROJECT=

# Azure (for authorized cloud testing — set per-engagement)
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# AZURE_SUBSCRIPTION_ID=

# ── NOTIFICATION / ALERTING ───────────────────────────────────────────
# Optional: AutoGPT monitoring alerts
SLACK_WEBHOOK_URL=                    # For monitoring alerts
DISCORD_WEBHOOK_URL=                  # Alternative alert channel
ALERT_EMAIL=                          # SMTP alert destination

# ── NETWORK / DOCKER ──────────────────────────────────────────────────
REDTEAM_NETWORK_SUBNET=172.25.0.0/24
REDTEAM_NETWORK_NAME=redteam

# ── OPSEC ─────────────────────────────────────────────────────────────
# Enable strict mode — validates authorization before scans
ENFORCE_AUTH_CHECK=true
# Log all tool invocations to audit trail
ENABLE_AUDIT_LOG=true
AUDIT_LOG_PATH=./logs/audit.log
# Rotate tokens after N days (0 = disabled)
TOKEN_ROTATION_DAYS=7
