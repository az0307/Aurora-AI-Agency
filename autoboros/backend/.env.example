# ── AutoBoros backend environment ──────────────────────────────
# Copy to .env and fill real values. NEVER commit the real .env.

# Database (async drivers). Dev default is SQLite; prod uses Postgres.
DATABASE_URL=postgresql+asyncpg://autoboros:autoboros@db:5432/autoboros

# API binding + the public URL the API is reachable at (n8n callbacks use this)
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# Auth — CHANGE BOTH. In production the app refuses to boot on these defaults.
SECRET_KEY=change-me-to-a-long-random-string
AB_PASSWORD=change-me

# "development" | "production"  (production enforces non-default secrets)
ENV=development
LOG_LEVEL=INFO

# Comma-separated browser origins allowed by CORS (no "*")
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# n8n bridge
N8N_WEBHOOK_URL=http://localhost:5678/webhook/autoboros
N8N_API_KEY=

# MCP HTTP bridge
MCP_SERVER_URL=http://localhost:3001
# Filesystem sandbox root for the MCP stdio server (file_read/file_write)
MCP_WORKSPACE=~/autoboros_workspace
