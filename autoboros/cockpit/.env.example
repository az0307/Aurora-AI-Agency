# ── AutoBoros cockpit (Vite) environment ───────────────────────
# Copy to .env. Vite only exposes vars prefixed with VITE_.

# REST base. Must end at /api/v1. For a deployed API use its public https URL.
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket endpoint. wss:// when the API is served over https.
VITE_WS_URL=ws://localhost:8000/api/v1/ws

# Base path for the built site. "/" for a root domain; "/<repo>/" for GitHub Pages.
VITE_BASE=/
